# GitHub Pages の最終公開 URL。未設定時は GitHub Actions 上で repository 名から推定します。
# このリポジトリの場合:
# PUBLIC_SITE_URL=https://dueyama.github.io

# ユーザー/Organization サイトなら "/"、プロジェクトサイトなら "/REPOSITORY/"。
# このリポジトリの場合:
# PUBLIC_BASE_PATH=/jyousenji-dayori/

# OneSignal App ID。未設定なら通知機能だけ無効化されます。
# PUBLIC_ONESIGNAL_APP_ID=777c076c-c65b-4695-8058-28e2476c85e9

# 未設定のリンクや連絡先は画面に表示されません。
# PUBLIC_GOOGLE_SITES_URL=
# PUBLIC_LINE_URL=
# PUBLIC_TEMPLE_ADDRESS=
# PUBLIC_MAP_URL=
# PUBLIC_TEMPLE_PHONE=

# ローカルの布教師名簿。実ファイルはリポジトリ外に置き、実パスは .env にだけ書きます。
# JYOUSENJI_TEACHERS_FILE=
