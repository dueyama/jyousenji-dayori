---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import ShareButton from "../../components/ShareButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateTime } from "../../lib/dates";

export async function getStaticPaths() {
  const notices = await getCollection("notices", ({ data }) => !data.draft);
  return notices.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  canonicalPath={`/notices/${entry.id}/`}
>
  <article class="content-page">
    <header class="page-title">
      <p class="article-meta">
        <time datetime={entry.data.publishedAt}
          >{formatDateTime(entry.data.publishedAt)}</time
        >
        <span>{entry.data.category}</span>
        {
          entry.data.updatedAt && (
            <span>
              更新:{" "}
              <time datetime={entry.data.updatedAt}>
                {formatDateTime(entry.data.updatedAt)}
              </time>
            </span>
          )
        }
      </p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <ShareButton title={entry.data.title} text={entry.data.summary} />
    </header>

    {
      entry.data.heroImage && entry.data.heroAlt && (
        <figure class="hero-image">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.heroAlt}
            widths={[640, 960, 1280]}
            sizes="(min-width: 840px) 820px, calc(100vw - 32px)"
          />
        </figure>
      )
    }

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
