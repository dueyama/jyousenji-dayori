---
import Icon from "../components/Icon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBasePath } from "../lib/urls";
---

<BaseLayout title="通知を受け取る" canonicalPath="/notifications/">
  <section class="content-page">
    <div class="page-title">
      <h1>通知を受け取る</h1>
      <p>
        大切なお知らせや行事予定を、希望する方だけにプッシュ通知でお届けします。
      </p>
    </div>

    <div class="notification-panel">
      <p
        id="notification-status"
        class="notification-status"
        role="status"
        aria-live="polite"
      >
        通知の状態を確認しています。
      </p>
      <button
        id="notification-button"
        class="button button--wide"
        type="button"
      >
        <Icon name="bell" />
        通知を受け取る
      </button>
      <p>
        ブラウザーの確認画面が出たら「許可」を選んでください。通知が不要になった場合は、端末またはブラウザーの設定から停止できます。
      </p>
    </div>

    <section
      class="section section--after-fixed-nav prose"
      aria-labelledby="ios-title"
    >
      <h2 id="ios-title">iPhone／iPadの場合</h2>
      <ol>
        <li>Safariでこのサイトを開きます。</li>
        <li>共有ボタンから「ホーム画面に追加」を選びます。</li>
        <li>
          追加したホーム画面のアイコンから開き、このページのボタンを押します。
        </li>
      </ol>
    </section>

    <section class="section prose" aria-labelledby="android-title">
      <h2 id="android-title">Androidの場合</h2>
      <ol>
        <li>Chromeなど対応ブラウザーでこのサイトを開きます。</li>
        <li>このページの「通知を受け取る」を押します。</li>
        <li>必要に応じて、ブラウザーのメニューからホーム画面へ追加します。</li>
      </ol>
    </section>

    <p>
      <a class="button button--secondary" href={withBasePath("/guide/")}
        >ホーム画面への追加手順を見る</a
      >
    </p>
  </section>

  <script>
    const status = document.querySelector<HTMLElement>("#notification-status");
    const button = document.querySelector<HTMLButtonElement>(
      "#notification-button",
    );

    const setStatus = (message: string) => {
      if (status) {
        status.textContent = message;
      }
    };

    const isIos = () =>
      /iPad|iPhone|iPod/.test(navigator.userAgent) ||
      (navigator.userAgent.includes("Mac") && navigator.maxTouchPoints > 1);

    const isStandalone = () =>
      window.matchMedia("(display-mode: standalone)").matches ||
      (window.navigator as Navigator & { standalone?: boolean }).standalone ===
        true;

    const waitForOneSignal = () =>
      new Promise<OneSignalWebSdk>((resolve, reject) => {
        if (!window.JOSENJI_ONESIGNAL_CONFIG?.appId) {
          reject(new Error("通知機能は準備中です。"));
          return;
        }

        if (
          window.JOSENJI_ONESIGNAL_READY &&
          window.JOSENJI_ONESIGNAL_INSTANCE
        ) {
          resolve(window.JOSENJI_ONESIGNAL_INSTANCE);
          return;
        }

        const timeout = window.setTimeout(() => {
          window.removeEventListener("jyousenji:onesignal-ready", handleReady);
          window.removeEventListener("jyousenji:onesignal-error", handleError);
          reject(
            new Error(
              "通知の準備に時間がかかっています。しばらくしてからお試しください。",
            ),
          );
        }, 8000);

        const handleReady = () => {
          window.clearTimeout(timeout);
          window.removeEventListener("jyousenji:onesignal-error", handleError);
          if (window.JOSENJI_ONESIGNAL_INSTANCE) {
            resolve(window.JOSENJI_ONESIGNAL_INSTANCE);
          } else {
            reject(new Error("通知の状態を確認できませんでした。"));
          }
        };

        const handleError = () => {
          window.clearTimeout(timeout);
          window.removeEventListener("jyousenji:onesignal-ready", handleReady);
          reject(
            new Error(
              window.JOSENJI_ONESIGNAL_ERROR ||
                "通知の状態を確認できませんでした。",
            ),
          );
        };

        window.addEventListener("jyousenji:onesignal-ready", handleReady, {
          once: true,
        });
        window.addEventListener("jyousenji:onesignal-error", handleError, {
          once: true,
        });
      });

    const delay = (milliseconds: number) =>
      new Promise((resolve) => window.setTimeout(resolve, milliseconds));

    const readPushState = (oneSignal: OneSignalWebSdk) => ({
      supported: oneSignal.Notifications.isPushSupported(),
      permission: oneSignal.Notifications.permission,
      optedIn: oneSignal.User.PushSubscription.optedIn,
    });

    const waitForSettledPushState = async (
      oneSignal: OneSignalWebSdk,
      timeoutMilliseconds = 5000,
    ) => {
      const startedAt = Date.now();
      let state = readPushState(oneSignal);
      while (
        state.supported &&
        state.permission &&
        !state.optedIn &&
        Date.now() - startedAt < timeoutMilliseconds
      ) {
        await delay(400);
        state = readPushState(oneSignal);
      }
      return state;
    };

    let oneSignalListenersAttached = false;

    const attachOneSignalListeners = (oneSignal: OneSignalWebSdk) => {
      if (oneSignalListenersAttached) {
        return;
      }
      oneSignalListenersAttached = true;
      oneSignal.Notifications.addEventListener("permissionChange", () => {
        void refreshState();
      });
      oneSignal.User.PushSubscription.addEventListener("change", () => {
        void refreshState();
      });
    };

    const showRegistered = () => {
      setStatus("通知は登録済みです。");
      if (button) {
        button.textContent = "通知は登録済みです";
        button.disabled = true;
      }
    };

    const refreshState = async () => {
      if (!button) {
        return;
      }

      button.disabled = true;
      setStatus("通知の設定を確認しています。少しお待ちください。");

      const config = window.JOSENJI_ONESIGNAL_CONFIG;
      if (!config?.appId) {
        button.disabled = true;
        setStatus(
          "通知機能は準備中です。お知らせと行事予定は通常どおり閲覧できます。",
        );
        return;
      }

      if (
        !("Notification" in window) ||
        !("serviceWorker" in navigator) ||
        !window.isSecureContext
      ) {
        button.disabled = true;
        setStatus("この端末またはブラウザーでは通知を利用できません。");
        return;
      }

      if (isIos() && !isStandalone()) {
        button.disabled = true;
        setStatus(
          "iPhone／iPadでは、先にホーム画面へ追加し、そのアイコンから開いてください。",
        );
        return;
      }

      if (Notification.permission === "denied") {
        button.disabled = true;
        setStatus(
          "通知が拒否されています。変更する場合はブラウザーまたは端末の設定を開いてください。",
        );
        return;
      }

      try {
        const oneSignal = await waitForOneSignal();
        attachOneSignalListeners(oneSignal);
        const state = await waitForSettledPushState(oneSignal);
        if (!state.supported) {
          button.disabled = true;
          setStatus("このブラウザーでは通知を利用できません。");
          return;
        }

        if (state.permission && state.optedIn) {
          showRegistered();
        } else {
          setStatus("通知はまだ登録されていません。");
          button.disabled = false;
        }
      } catch (error) {
        button.disabled = true;
        setStatus(
          error instanceof Error
            ? error.message
            : "通知の状態を確認できませんでした。",
        );
      }
    };

    button?.addEventListener("click", async () => {
      if (!button) {
        return;
      }

      button.disabled = true;
      setStatus("通知の許可を確認しています。");

      try {
        const oneSignal = await waitForOneSignal();
        attachOneSignalListeners(oneSignal);
        if (!oneSignal.Notifications.isPushSupported()) {
          setStatus("このブラウザーでは通知を利用できません。");
          return;
        }

        await oneSignal.Notifications.requestPermission();

        if (oneSignal.Notifications.permission) {
          await oneSignal.User.PushSubscription.optIn();
          const state = await waitForSettledPushState(oneSignal);
          if (state.permission && state.optedIn) {
            showRegistered();
          } else {
            setStatus(
              "通知の許可は完了しました。登録状態を確認しています。少し待ってからもう一度開いてください。",
            );
            button.disabled = true;
          }
        } else {
          setStatus(
            "通知は許可されませんでした。必要な場合はブラウザーの設定から変更できます。",
          );
          button.disabled = false;
        }
      } catch {
        setStatus(
          "通知の設定に失敗しました。時間をおいてもう一度お試しください。",
        );
        button.disabled = false;
      }
    });

    window.addEventListener("pageshow", () => {
      void refreshState();
    });
    window.addEventListener("focus", () => {
      void refreshState();
    });
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        void refreshState();
      }
    });

    void refreshState();
  </script>
</BaseLayout>
