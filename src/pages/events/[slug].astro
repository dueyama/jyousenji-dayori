---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import ShareButton from "../../components/ShareButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateTime, formatEventSchedule } from "../../lib/dates";
import { withBasePath } from "../../lib/urls";

export async function getStaticPaths() {
  const events = await getCollection("events", ({ data }) => !data.draft);
  return events.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const statusLabel = {
  scheduled: "予定",
  cancelled: "中止",
  postponed: "延期",
} as const;
const eventSchedule = formatEventSchedule(entry.data);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  canonicalPath={`/events/${entry.id}/`}
>
  <article class="content-page">
    <header class="page-title">
      <p class="article-meta">
        <span
          class:list={["status-label", `status-label--${entry.data.status}`]}
        >
          {statusLabel[entry.data.status]}
        </span>
        <time datetime={entry.data.startAt}>{eventSchedule}</time>
      </p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <div class="action-row">
        <a
          class="button"
          href={withBasePath(`/events/${entry.id}.ics`)}
          download
        >
          カレンダーに追加
        </a>
        <ShareButton title={entry.data.title} text={entry.data.summary} />
      </div>
    </header>

    <div class="timeline" aria-label="行事情報">
      {
        entry.data.allDay ? (
          <div class="timeline__item">
            <strong>日程</strong>
            <time datetime={entry.data.startAt}>{eventSchedule}</time>
          </div>
        ) : (
          <>
            <div class="timeline__item">
              <strong>開始</strong>
              <time datetime={entry.data.startAt}>
                {formatDateTime(entry.data.startAt)}
              </time>
            </div>
            <div class="timeline__item">
              <strong>終了</strong>
              <time datetime={entry.data.endAt}>
                {formatDateTime(entry.data.endAt)}
              </time>
            </div>
          </>
        )
      }
      <div class="timeline__item">
        <strong>場所</strong>
        <span>{entry.data.location}</span>
      </div>
    </div>

    {
      entry.data.heroImage && entry.data.heroAlt && (
        <figure class="hero-image">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.heroAlt}
            widths={[640, 960, 1280]}
            sizes="(min-width: 840px) 820px, calc(100vw - 32px)"
          />
        </figure>
      )
    }

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
