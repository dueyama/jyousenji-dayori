---
import { getCollection } from "astro:content";
import EventList from "../components/EventList.astro";
import Icon from "../components/Icon.astro";
import NoticeList from "../components/NoticeList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { isFutureOrToday, sortByNewest, sortEventsByStart } from "../lib/dates";
import { withBasePath } from "../lib/urls";

const notices = sortByNewest(
  await getCollection("notices", ({ data }) => !data.draft),
).slice(0, 4);
const events = sortEventsByStart(
  (await getCollection("events", ({ data }) => !data.draft)).filter((event) =>
    isFutureOrToday(event.data.startAt),
  ),
).slice(0, 4);

const helperLinks = [
  {
    href: withBasePath("/guide/"),
    label: "利用案内",
    external: false,
  },
  {
    href: withBasePath("/about/"),
    label: "浄泉寺について",
    external: false,
  },
  {
    href: siteConfig.googleSitesUrl,
    label: "浄泉寺公式ページ",
    external: true,
  },
  {
    href: siteConfig.lineUrl,
    label: "公式LINE",
    external: true,
  },
].filter((link) => link.href);
---

<BaseLayout>
  <section class="hero" aria-labelledby="home-title">
    <div class="hero__copy">
      <h1 id="home-title">浄泉寺からのお知らせ</h1>
      <div class="action-row">
        <a class="button" href={withBasePath("/notifications/")}>
          <Icon name="bell" />
          通知を受け取る
        </a>
      </div>
      <nav class="hero__links" aria-label="補助リンク">
        {
          helperLinks.map((link) => (
            <a
              href={link.href}
              rel={link.external ? "noopener noreferrer" : undefined}
              target={link.external ? "_blank" : undefined}
            >
              {link.label}
              {link.external && <Icon name="external" />}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  <section class="section" aria-labelledby="latest-notices">
    <div class="section__header">
      <h2 id="latest-notices">最新のお知らせ</h2>
      <a href={withBasePath("/notices/")}>すべて見る</a>
    </div>
    <NoticeList notices={notices} />
  </section>

  <section class="section" aria-labelledby="upcoming-events">
    <div class="section__header">
      <h2 id="upcoming-events">行事予定</h2>
      <a href={withBasePath("/events/")}>すべて見る</a>
    </div>
    <EventList events={events} />
  </section>
</BaseLayout>
