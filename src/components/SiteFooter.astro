---
import Icon from "./Icon.astro";
import { siteConfig } from "../config/site";
import { withBasePath } from "../lib/urls";

const externalLinks = [
  { href: siteConfig.googleSitesUrl, label: "公式ページ" },
  { href: siteConfig.lineUrl, label: "公式LINE" },
  { href: siteConfig.mapUrl, label: "地図" },
].filter((link) => link.href);
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div>
      <p class="site-footer__name">{siteConfig.name}</p>
      {siteConfig.address && <p>{siteConfig.address}</p>}
      {siteConfig.phone && <p>電話: {siteConfig.phone}</p>}
    </div>
    <nav aria-label="補助メニュー">
      <a href={withBasePath("/about/")}>このサイトについて</a>
      <a href={withBasePath("/privacy/")}>プライバシー</a>
      <a href={withBasePath("/rss.xml")}>RSS</a>
      {
        externalLinks.map((link) => (
          <a href={link.href} rel="noopener noreferrer" target="_blank">
            {link.label}
            <Icon name="external" />
          </a>
        ))
      }
    </nav>
  </div>
</footer>
